{
  "manifest_version": 3,
  "name": "Kahoot Answer Helper",
  "version": "1.0.0",
  "description": "Muestra y auto-responde en Kahoot. Soporta quiz, múltiple selección, jumble, ordering y open_ended.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "https://*.kahoot.it/*",
    "https://*.kahoot.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.kahoot.it/*", "https://*.kahoot.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
