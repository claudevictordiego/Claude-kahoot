{
  "manifest_version": 3,
  "name": "Kahoot Question Observer",
  "version": "6.0.0",
  "description": "Intercepta respuestas de red de Kahoot para mostrar las opciones correctas.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "https://*.kahoot.it/*",
    "https://*.kahoot.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.kahoot.it/*", "https://*.kahoot.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
